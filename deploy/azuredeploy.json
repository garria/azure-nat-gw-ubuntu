{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": { "description": "Username amministratore VM" }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": { "description": "Password amministratore VM" }
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "vnet-gw"
    },
    "vnetAddressSpace": {
      "type": "string",
      "defaultValue": "10.10.0.0/16"
    },
    "gwSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.10.0.0/24"
    },
    "appSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.10.1.0/24"
    },
    "gatewayPrivateIp": {
      "type": "string",
      "defaultValue": "10.10.0.4",
      "metadata": { "description": "IP privato statico per la NIC del gateway" }
    },
    "vmName": {
      "type": "string",
      "defaultValue": "ubuntu-gateway"
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B1s"
    }
  },
  "variables": {
    "rtName": "rt-gateway",
    "pipName": "gw-pip",
    "nicName": "gw-nic",
