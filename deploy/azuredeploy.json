{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Regione di deploy (di default, quella del Resource Group)" }
    },
    "vmName": {
      "type": "string",
      "defaultValue": "ubuntu-gateway",
      "metadata": { "description": "Nome della VM gateway" }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B1s",
      "allowedValues": [
        "Standard_B1s",
        "Standard_B2s",
        "Standard_D2s_v3",
        "Standard_D4s_v3"
      ],
      "metadata": { "description": "Dimensione della VM" }
    },
    "ubuntuOffer": {
      "type": "string",
      "defaultValue": "0001-com-ubuntu-server-jammy",
      "allowedValues": [
        "0001-com-ubuntu-server-jammy",  // Ubuntu 22.04 LTS
        "0001-com-ubuntu-server-noble"   // Ubuntu 24.04 LTS
      ],
      "metadata": { "description": "Offerta Ubuntu (22.04 = jammy, 24.04 = noble)" }
    },
    "ubuntuSku": {
      "type": "string",
      "defaultValue": "22_04-lts",
      "allowedValues": [
        "22_04-lts",
        "24_04-lts"
      ],
      "metadata": { "description": "SKU Ubuntu (22_04-lts o 24_04-lts)" }
    },
    "osDiskType": {
      "type": "string",
      "defaultValue": "Standard_LRS",
      "allowedValues": [
        "Standard_LRS",
        "StandardSSD_LRS",
        "Premium_LRS"
      ],
      "metadata": { "description": "Tipo di disco OS" }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": { "description": "Username amministratore" }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": { "description": "Password amministratore" }
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "vnet-gw",
      "metadata": { "description": "Nome della VNet" }
    },
    "vnetAddressSpace": {
      "type": "string",
      "defaultValue": "10.10.0.0/16",
      "metadata": { "description": "CIDR della VNet (es. 10.10.0.0/16)" }
    },
    "natgwSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.10.0.0/24",
      "metadata": { "description": "CIDR della subnet del gateway (nome fisso: natgw)" }
    },
    "gatewayPrivateIp": {
      "type": "string",
      "defaultValue": "10.10.0.4",
      "metadata": { "description": "IP privato STATICO per la NIC del gateway (DEVE essere dentro natgwSubnetPrefix)" }
    }
  },
  "variables": {
    "pipName": "gw-pip",
    "nicName": "gw-nic",
    "subnetName": "natgw",
    "rtName": "rt-gateway", 
    "cloudInit": "#cloud-config\npackage_update: true\npackages:\n  - iptables\n  - netfilter-persistent\n  - iproute2\nwrite_files:\n  - path: /usr/local/bin/setup-gateway.sh\n    permissions: '0755'\n    content: |\n      #!/bin/bash\n      echo \"[+] Configuring Ubuntu as NAT Gateway\"\n      echo 1 > /proc/sys/net/ipv4/ip_forward\n      sed -i '/net.ipv4.ip_forward/d' /etc/sysctl.conf\n      echo \"net.ipv4.ip_forward=1\" >> /etc/sysctl.conf\n      IFACE=\"eth0\"\n      iptables -t nat -A POSTROUTING -o $IFACE -j MASQUERADE\n      netfilter-persistent save\n      echo \"[✓] Gateway Ready.\"\nruncmd:\n  - /usr/local/bin/setup-gateway.sh\n"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[parameters('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [ "[parameters('vnetAddressSpace')]" ]
        },
        "subnets": [
          {
            "name": "[variables('subnetName')]",
            "properties": {
              "addressPrefix": "[parameters('natgwSubnetPrefix')]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-09-01",
      "name": "[variables('pipName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard" },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('nicName')]",
      "location": "[parameters('location')]",
      "properties": {
        "enableIPForwarding": true,
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
