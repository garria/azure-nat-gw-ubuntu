{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": { "description": "Username amministratore VM" }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": { "description": "Password amministratore VM" }
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "vnet-gw"
    },
    "vnetAddressSpace": {
      "type": "string",
      "defaultValue": "10.10.0.0/16"
    },
    "gwSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.10.0.0/24"
    },
    "appSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.10.1.0/24"
    },
    "gatewayPrivateIp": {
      "type": "string",
      "defaultValue": "10.10.0.4",
      "metadata": { "description": "IP privato statico per la NIC del gateway" }
    },
    "vmName": {
      "type": "string",
      "defaultValue": "ubuntu-gateway"
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B1s"
    }
  },
  "variables": {
    "rtName": "rt-gateway",
    "pipName": "gw-pip",
    "nicName": "gw-nic",
    "cloudInit": "#cloud-config\npackage_update: true\npackages:\n  - iptables\n  - netfilter-persistent\n  - iproute2\nwrite_files:\n  - path: /usr/local/bin/setup-gateway.sh\n    permissions: '0755'\n    content: |\n      #!/bin/bash\n      echo \"[+] Configuring Ubuntu as NAT Gateway\"\n      echo 1 > /proc/sys/net/ipv4/ip_forward\n      sed -i '/net.ipv4.ip_forward/d' /etc/sysctl.conf\n      echo \"net.ipv4.ip_forward=1\" >> /etc/sysctl.conf\n      IFACE=\"eth0\"\n      iptables -t nat -A POSTROUTING -o $IFACE -j MASQUERADE\n      netfilter-persistent save\n      echo \"[✓] Gateway Ready.\"\nruncmd:\n  - /usr/local/bin/setup-gateway.sh\n"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[parameters('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetAddressSpace')]"
          ]
        },
        "subnets": [
          {
            "name": "GatewaySubnet",
            "properties": {
              "addressPrefix": "[parameters('gwSubnetPrefix')]"
            }
          },
          {
            "name": "AppSubnet",
            "properties": {
              "addressPrefix": "[parameters('appSubnetPrefix')]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-09-01",
      "name": "[variables('rtName')]",
      "location": "[parameters('location')]",
      "properties": {
        "routes": [
          {
            "name": "default-route",
            "properties": {
              "addressPrefix": "0.0.0.0/0",
              "nextHopType": "VirtualAppliance",
              "nextHopIpAddress": "[parameters('gatewayPrivateIp')]"
            }
          }
        ]
      }
    },
    {
